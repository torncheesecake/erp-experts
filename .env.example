# Sentinel runtime environment example
# Placeholder values only. Do not put real secrets in this file.

# Runtime
NODE_ENV=production

# Sentinel platform paths
PLATFORM_DB_PATH=/srv/sentinel/data/seo-ops/platform.db
PLATFORM_REPORTS_PATH=/srv/sentinel/data/seo-ops/reports
# Local/dev default used by readiness checks. On the Raspberry Pi, use:
# PLATFORM_BACKUP_PATH=/srv/sentinel/data/seo-ops/backups
PLATFORM_BACKUP_PATH=platform/persistence/backups
PLATFORM_LOG_PATH=/srv/sentinel/logs/seo-ops

# Tenant defaults
PLATFORM_TENANT=erp-experts
PLATFORM_BASE_URL=https://example.yourdomain.co.uk
PLATFORM_DASHBOARD_ROUTE=/seo-roadmap

# Local operator dashboard API experiment
# Use only for local Sentinel operator testing. Do not expose publicly without auth.
# Example local value when deliberately testing: http://127.0.0.1:4317
VITE_SENTINEL_API_BASE_URL=

# Future Sentinel remote authority placeholders
# Planning only. Do not commit real tokens or passwords.
SENTINEL_REMOTE_AUTH_MODE=disabled
SENTINEL_REMOTE_API_BASE_URL=
SENTINEL_OPERATOR_TOKEN=
VITE_SENTINEL_REQUIRE_REMOTE_AUTH=false

# Security placeholders
BASIC_AUTH_USER=replace-me
BASIC_AUTH_PASSWORD=replace-me
SENTINEL_AUTH_MODE=none
SENTINEL_OPERATOR_USER=
SENTINEL_OPERATOR_PASSWORD=
SENTINEL_PUBLIC_STAKEHOLDER_ROUTES=/seo-progress

# Deployment
GITHUB_REPO=https://github.com/example/example-repo.git
DEPLOY_ROOT=/srv/sentinel

# Raspberry Pi discovery placeholders
# Local setup guide: docs/RASPBERRY_PI_LOCAL_ENV_SETUP.md
# Do not put passwords or private keys in this file.
RASPBERRY_PI_HOST=192.168.4.22
RASPBERRY_PI_USER=
RASPBERRY_PI_SSH_PORT=22
RASPBERRY_PI_DEPLOY_ROOT=/srv/sentinel
RASPBERRY_PI_APP_PATH=/srv/sentinel/apps/seo-ops

# Backup
BACKUP_RETENTION_DAYS=30
