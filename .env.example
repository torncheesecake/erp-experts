# Sentinel runtime environment example
# Placeholder values only. Do not put real secrets in this file.

# Runtime
NODE_ENV=production

# Sentinel platform paths
PLATFORM_DB_PATH=/srv/matthew-platform/data/seo-ops/platform.db
PLATFORM_REPORTS_PATH=/srv/matthew-platform/data/seo-ops/reports
PLATFORM_BACKUP_PATH=/srv/matthew-platform/data/seo-ops/backups
PLATFORM_LOG_PATH=/srv/matthew-platform/logs/seo-ops

# Tenant defaults
PLATFORM_TENANT=erp-experts
PLATFORM_BASE_URL=https://example.yourdomain.co.uk
PLATFORM_DASHBOARD_ROUTE=/seo-roadmap

# Security placeholders
BASIC_AUTH_USER=replace-me
BASIC_AUTH_PASSWORD=replace-me

# Deployment
GITHUB_REPO=https://github.com/example/example-repo.git
DEPLOY_ROOT=/srv/matthew-platform

# Backup
BACKUP_RETENTION_DAYS=30
